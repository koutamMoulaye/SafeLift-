# =============================================================================
# SafeLift - Variables d'environnement (exemple)
# Copier ce fichier en ".env" puis adapter les valeurs si besoin.
# Ne JAMAIS committer le fichier ".env" reel (secrets/mots de passe).
# =============================================================================

# --- Prefixe du projet, utilise pour nommer le reseau Docker et eviter les
# --- collisions avec d'autres projets Docker lances en parallele sur la machine
COMPOSE_PROJECT_NAME=safelift

# --- Zookeeper ---
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_PORT_EXPOSED=12181

# --- Kafka ---
KAFKA_BROKER_ID=1
# Port interne au reseau docker (utilise par les autres services du compose)
KAFKA_INTERNAL_PORT=9092
# Port expose sur l'hote (pour se connecter depuis l'exterieur du reseau docker)
KAFKA_EXTERNAL_PORT_EXPOSED=19092
KAFKA_TEST_TOPIC=safelift-test-topic
# Topic DEDIE au streaming d'affluence (Jalon 2, sous-etape 1/5) -- distinct
# du topic de test ci-dessus (verification initiale du broker uniquement).
KAFKA_GYM_OCCUPANCY_TOPIC=safelift-gym-occupancy
# Topic DEDIE aux saisies de seance temps reel (Jalon 2, sous-etape 3/5) :
# POST /users/{user_id}/sessions (dashboard) publie ici, jamais d'ecriture
# DB directe depuis l'API -- decouplage evenementiel, voir CLAUDE.md.
KAFKA_USER_INPUTS_TOPIC=safelift-user-inputs

# --- Spark (standalone: 1 master + 1 worker) ---
SPARK_MASTER_UI_PORT_EXPOSED=18080
SPARK_MASTER_PORT_EXPOSED=17077
SPARK_WORKER_UI_PORT_EXPOSED=18081
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=2g

# --- PostgreSQL applicatif (futur data warehouse / schema en etoile) ---
APP_POSTGRES_USER=safelift_app
APP_POSTGRES_PASSWORD=change_me_app
APP_POSTGRES_DB=safelift_dwh
APP_POSTGRES_PORT_EXPOSED=15432

# --- PostgreSQL dedie a Airflow (metadata DB, distinct du Postgres applicatif) ---
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=change_me_airflow
AIRFLOW_POSTGRES_DB=airflow_metadata
AIRFLOW_POSTGRES_PORT_EXPOSED=15433

# --- Airflow ---
AIRFLOW_WEBSERVER_PORT_EXPOSED=18089
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=change_me_admin
AIRFLOW_ADMIN_FIRSTNAME=Safelift
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@safelift.local

# --- Dashboard (FastAPI placeholder) ---
DASHBOARD_PORT_EXPOSED=18000

# --- Gouvernance RGPD : pseudonymisation HMAC-SHA256 (etape 6/6, sous-etape 4/6) ---
# Cle secrete utilisee UNIQUEMENT par scripts/pseudonymize.py, pour calculer
# user_pseudo_id (HMAC-SHA256 de user_id) avant tout export vers S3/Athena
# (couche de restitution externe -- voir CLAUDE.md). NE JAMAIS reutiliser la
# valeur factice ci-dessous en dehors d'un environnement de demo/dev local :
# generer une vraie cle forte avec, par exemple :
#   python -c "import secrets; print(secrets.token_hex(32))"
# Si cette cle est un jour perdue ou changee, TOUS les user_pseudo_id deja
# exportes vers S3 deviennent definitivement non-recalculables a l'identique
# (propriete voulue : c'est un secret, pas un identifiant reversible).
PSEUDONYMIZATION_KEY=changeme_generate_a_real_random_hex_key_before_any_real_export

# --- Simulateur d'affluence (Jalon 2, sous-etape 1/5 -- scripts/simulate_gym_occupancy.py) ---
# Intervalle (secondes) entre 2 cycles d'emission (1 message par salle de
# gold.dim_gym a chaque cycle) -- une duree est tiree aleatoirement dans
# [MIN, MAX] a chaque cycle, pour eviter un rythme parfaitement regulier.
GYM_SIMULATOR_INTERVAL_MIN_SECONDS=5
GYM_SIMULATOR_INTERVAL_MAX_SECONDS=10
